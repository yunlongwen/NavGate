{
  "name": "navgate",
  "version": "2.0.0",
  "description": "An elegant, modern personal website navigation management system - supports dual-mode deployment",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter server dev",
    "build": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter server build",
    "preview": "pnpm --filter frontend preview",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "deploy:github-pages": "pnpm --filter frontend build && gh-pages -d apps/frontend/dist",
    "deploy:aliyun": "docker/scripts/deploy-aliyun.sh",
    "test": "pnpm -r test",
    "hash-password": "tsx scripts/hash-password.ts",
    "prepare": "husky install",
    "commit": "commitlint --edit",
    "lint-staged": "lint-staged",
    "prepare-commit-msg": "commitlint --commit-msg",
    "postcommit": "git push --follow-tags"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.2.5",
    "@mui/icons-material": "^7.0.1",
    "@mui/material": "^7.0.1",
    "@navgate/types": "workspace:*",
    "@navgate/utils": "workspace:*",
    "@tailwindcss/vite": "^4.1.2",
    "bcrypt": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@commitlint/format": "^19.2.0",
    "@eslint/js": "^9.39.3",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-react": "^4.3.4",
    "commitlint": "^19.6.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "gh-pages": "^6.1.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.2.8",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
