# 部署模式：github-pages 或 backend
VITE_DEPLOY_MODE=github-pages

# ===== 后端模式配置 =====

# 数据库配置
DATABASE_URL=mysql://root:password@localhost:3306/navgate

# JWT 配置
JWT_SECRET=your-super-secret-jwt-key-change-this

# 认证配置
AUTH_USERNAME=admin
AUTH_PASSWORD=$2a$10$abcdefghijklmnopqrstuvwxyz

# ===== GitHub Pages 配置 =====

# GitHub Pages 模式不需要额外配置

# ===== 阿里云部署配置 =====

# 阿里云 ECS 配置
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_REGION=cn-hangzhou
ALIYUN_ECS_INSTANCE_ID=i-xxxxxxxxx
ALIYUN_ECS_SSH_KEY=/path/to/ssh/key

# 阿里云容器镜像仓库
ALIYUN_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_REGISTRY_NAMESPACE=your-namespace
ALIYUN_REGISTRY_USERNAME=your-username
ALIYUN_REGISTRY_PASSWORD=your-password
