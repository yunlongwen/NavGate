# ============================================
# 部署模式配置 / Deployment Mode Configuration
# ============================================
# 
# 选择一种模式 / Choose one mode:
# - github-pages: localStorage 存储（默认）/ localStorage storage (default)
# - gist: GitHub Gist 存储（推荐）/ GitHub Gist storage (recommended) ⭐
# - backend: 后端模式 / Backend mode
#
VITE_DEPLOY_MODE=github-pages

# ===== GitHub Gist 模式配置 / Gist Mode Configuration =====
# 
# 如果使用 Gist 模式，需要配置以下变量：
# If using Gist mode, configure these variables:
#
# VITE_GIST_ID=your_gist_id_here
# VITE_GITHUB_TOKEN=ghp_your_token_here
#
# 设置步骤 / Setup Steps:
# 1. 创建 GitHub Token (gist 权限) / Create GitHub Token (gist scope)
#    https://github.com/settings/tokens
# 2. 创建 Gist 存储数据 / Create Gist for data storage
#    https://gist.github.com/
# 3. 详见 ENV_CONFIG_GUIDE.md / See ENV_CONFIG_GUIDE.md for details

# ===== 管理员配置 / Admin Configuration =====
#
# 管理员登录凭证（适用于 github-pages 和 gist 模式）
# Admin login credentials (for github-pages and gist modes)
# 如果不配置，任意凭证即可登录 / If not set, any credentials will work
#
# VITE_ADMIN_USERNAME=admin
# VITE_ADMIN_PASSWORD=your-password-here

# ===== 后端模式配置 / Backend Mode Configuration =====

# 认证配置
AUTH_USERNAME=admin
AUTH_PASSWORD=$2a$10$abcdefghijklmnopqrstuvwxyz

# ===== 前端 API 配置 / Frontend API Configuration =====

# 后端模式需要配置 API 地址 / Backend mode requires API URL
# VITE_API_BASE_URL=http://localhost:3000

# ===== 阿里云部署配置 =====

# 阿里云 ECS 配置
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_REGION=cn-hangzhou
ALIYUN_ECS_INSTANCE_ID=i-xxxxxxxxx
ALIYUN_ECS_SSH_KEY=/path/to/ssh/key

# 阿里云容器镜像仓库
ALIYUN_REGISTRY=registry.cn-hangzhou.aliyuncs.com
ALIYUN_REGISTRY_NAMESPACE=your-namespace
ALIYUN_REGISTRY_USERNAME=your-username
ALIYUN_REGISTRY_PASSWORD=your-password
