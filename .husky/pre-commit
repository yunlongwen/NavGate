#!/bin/bash

echo "🔍 Running pre-commit hook..."

# Stage all changes
if [ -z "$(git diff --cached --name-only)" ]; then
  echo "❌ No staged changes found"
  echo "Use 'git add .' to stage changes before committing."
  exit 1
fi

# Run lint-staged (lints + formats)
echo "▶ Running lint-staged..."
pnpm exec lint-staged || {
  echo "❌ lint-staged failed"
  echo "Please fix linting errors before committing."
  echo "Run 'pnpm run lint' to see all errors."
  exit 1
}

# Format check is already done by lint-staged above
# No need for separate prettier run

echo "✅ Pre-commit checks passed!"
